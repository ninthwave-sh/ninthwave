# OS files
.DS_Store

# ninthwave worktrees
.worktrees/

# Machine-specific bundle location (created by setup)
.ninthwave/dir

# Orchestrator runtime files (ephemeral, created/deleted during runs)
.ninthwave/orchestrator.state.json
.ninthwave/health-samples.jsonl
.ninthwave/version

# Claude Code per-user data (created in worktrees by workers)
.claude/projects/
.claude/worktrees/

# Generated tool artifacts for this repo only
# Canonical sources live in skills/, agents/, and CLAUDE.md.
# Normal user repos can choose their own tracking policy.
/.claude/agents/
/.claude/skills/
/.codex/agents/
/.opencode/agents/
/.github/agents/
/.github/copilot-instructions.md

# OpenCode local plans
.opencode/plans/

# Node/Bun dependencies
node_modules/

# Build artifacts
dist/

# GitHub Actions require compiled dist to be committed
!actions/*/dist/
